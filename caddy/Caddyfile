    # Running on proxmox
    @ntfy host ntfy.home.brianpooe.com
    handle @ntfy {
        reverse_proxy 192.168.10.6:80
    }

    # pihole running on a raspberry pi different vlan
    @pihole host pihole.home.brianpooe.com
    handle @pihole {
        encode zstd gzip
        rewrite * /admin{uri}
        reverse_proxy 192.168.60.5:80
    }

