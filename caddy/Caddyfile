(authenticate) {
    reverse_proxy /outpost.goauthentik.io/* http://192.168.10.7:9000

    forward_auth http://192.168.10.7:9000 {
        uri /outpost.goauthentik.io/auth/caddy
        copy_headers X-Authentik-Username X-Authentik-Groups X-Authentik-Email X-Authentik-Name X-Authentik-Uid X-Authentik-Jwt X-Authentik-Meta-Jwks X-Authentik-Meta-Outpost X-Authentik-Meta-Provider X-Authentik-Meta-App X-Authentik-Meta-Version
        trusted_proxies private_ranges
    }
}

{
    admin :2019
}

*.home.brianpooe.com {
    tls {
        dns cloudflare {env.DNS_PROVIDER_TOKEN}
    }

    @switchlite8poe host switchlite8poe.home.brianpooe.com
    handle @switchlite8poe {
        reverse_proxy 192.168.1.5
    }

    @tplink16de host tplink16de.home.brianpooe.com
    handle @tplink16de {
        reverse_proxy 192.168.1.8
    }

    # Proxmox
    @proxmox host proxmox.home.brianpooe.com
    handle @proxmox {
        reverse_proxy 192.168.10.10:8006 {
            transport http {
                tls_insecure_skip_verify
            }
            header_up Host {upstream_hostport}
        }

        header {
            Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
            X-Content-Type-Options "nosniff"
            X-Frame-Options "SAMEORIGIN"
            Referrer-Policy "no-referrer"
        }

        encode gzip
    }

    # Proxmox Backup Server
    @pbs host pbs.home.brianpooe.com
    handle @pbs {
        reverse_proxy 192.168.10.8:8007 {
            transport http {
                tls_insecure_skip_verify
            }
            header_up Host {upstream_hostport}
        }

        header {
            Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
            X-Content-Type-Options "nosniff"
            X-Frame-Options "SAMEORIGIN"
            Referrer-Policy "no-referrer"
        }

        encode gzip
    }

    # pihole running on a raspberry pi different vlan
    @pihole host pihole.home.brianpooe.com
    handle @pihole {
        encode zstd gzip
        rewrite * /admin{uri}
        reverse_proxy 192.168.60.5:80
    }

