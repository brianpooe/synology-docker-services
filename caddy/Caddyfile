*.home.brianpooe.com {
    tls {
        dns cloudflare {env.DNS_PROVIDER_TOKEN}
    }

    @unifi host unifi.home.brianpooe.com
    handle @unifi {
        reverse_proxy 192.168.10.15:8443 {
            transport http {
                tls_insecure_skip_verify
            }
        }
    }

    @tplink8pe host tplink8pe.home.brianpooe.com
    handle @tplink8pe {
        reverse_proxy 192.168.1.9
    }

    @tplink16de host tplink16de.home.brianpooe.com
    handle @tplink16de {
        reverse_proxy 192.168.1.8
    }

    # Proxmox
    @proxmox host proxmox.home.brianpooe.com
    handle @proxmox {
        reverse_proxy 192.168.10.10:8006 {
            transport http {
                tls_insecure_skip_verify
            }
            header_up Host {upstream_hostport}
        }

        header {
            Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
            X-Content-Type-Options "nosniff"
            X-Frame-Options "SAMEORIGIN"
            Referrer-Policy "no-referrer"
        }

        encode gzip
    }

    # Running on proxmox
    @pdf host pdf.home.brianpooe.com
    handle @pdf {
        reverse_proxy 192.168.10.12:8080
    }
    # Running on proxmox
    # https://github.com/paperless-ngx/paperless-ngx/wiki/Using-a-Reverse-Proxy-with-Paperless-ngx#nginx
    @paperless host paperless-ngx.home.brianpooe.com
    handle @paperless {
        reverse_proxy 192.168.10.13:8000 {
            header_down Referrer-Policy "strict-origin-when-cross-origin"
        }
    }
    # Running on proxmox
    @homepage host homepage.home.brianpooe.com
    handle @homepage {
        reverse_proxy 192.168.10.14:3000
    }

    # Running on proxmox
    @uptimekuma host uptimekuma.home.brianpooe.com
    handle @uptimekuma {
        reverse_proxy 192.168.10.16:3001
    }

    # Running on proxmox
    @minio host minio.home.brianpooe.com
    handle @minio {
        reverse_proxy 192.168.10.9:9001
    }

    # Running on proxmox
    @minioapi host minio-api.home.brianpooe.com
