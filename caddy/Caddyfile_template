# Proxmox Backup Server
pbs.{{CADDY_BASE_DOMAIN:-home.example.com}} {
    import common
    reverse_proxy {{CADDY_OFFICE_PREFIX:-10.10.0}}.8:8007 {
        import office-admin-upstream
    }
    import office-admin-security
}

# Proxmox
