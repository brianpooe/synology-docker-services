fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="840" y="430" width="720" height="130" as="geometry" /></mxCell><mxCell id="21" value="Legend&#xa;Green solid arrow: allow path (policy intent)&#xa;Blue dashed arrow: DNS path to AdBlock resolver&#xa;Red dashed note: unresolved/needs validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="80" y="620" width="600" height="120" as="geometry" /></mxCell><mxCell id="100" value="Office has broad internal access" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=2;" edge="1" parent="1" source="11" target="10"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="101" value="Allow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=2;" edge="1" parent="1" source="11" target="13"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="102" value="Allow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=2;" edge="1" parent="1" source="11" target="14"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="103" value="Allow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=2;" edge="1" parent="1" source="11" target="15"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="104" value="Allow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#2D7600;strokeWidth=2;" edge="1" parent="1" source="11" target="16"><mxGeometry relative="1" as="geometry" /></mxCell>